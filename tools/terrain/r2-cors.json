{
  "rules": [
    {
      "allowed": {
        "origins": ["*"],
        "methods": ["GET", "HEAD"],
        "headers": ["Range", "If-None-Match"]
      },
      "exposeHeaders": [
        "Accept-Ranges",
        "Cache-Control",
        "Content-Length",
        "Content-Range",
        "ETag"
      ],
      "maxAgeSeconds": 86400
    }
  ]
}
