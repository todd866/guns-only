#!/bin/sh
# bin/rig <scenario-name> [--resolution WxH]
#
# Flight-test rig runner: drives testrig/rig.gd (the "Rig" autoload) through a
# scripted scenario under Godot movie-mode frame capture, then prints a compact
# report of what happened -- frame count, a handful of sample frames, the last
# telemetry line, and the done.json summary. No human needed at the controls.
set -eu

SCRIPT_DIR=$(cd "$(dirname "$0")" && pwd)
ROOT_DIR=$(cd "$SCRIPT_DIR/.." && pwd)

if [ $# -lt 1 ]; then
    echo "usage: bin/rig <scenario-name> [--resolution WxH]" >&2
    exit 1
fi

NAME="$1"; shift
RESOLUTION="1280x720"
while [ $# -gt 0 ]; do
    case "$1" in
        --resolution)
            RESOLUTION="$2"
            shift 2
            ;;
        *)
            echo "unknown argument: $1" >&2
            exit 1
            ;;
    esac
done

SCENARIO_JSON="$ROOT_DIR/testrig/scenarios/$NAME.json"
if [ ! -f "$SCENARIO_JSON" ]; then
    echo "no such scenario: $SCENARIO_JSON" >&2
    exit 1
fi

OUT_DIR="$ROOT_DIR/testrig/out/$NAME"
rm -rf "$OUT_DIR"
mkdir -p "$OUT_DIR"

export GUNS_RIG_SCENARIO="$SCENARIO_JSON"
export GUNS_RIG_OUT="$OUT_DIR"

"$ROOT_DIR/bin/godot" --path "$ROOT_DIR" \
    --write-movie "$OUT_DIR/f.png" \
    --fixed-fps 30 \
    --resolution "$RESOLUTION"

echo "=== $NAME ==="

FRAMES=$(ls "$OUT_DIR"/f*.png 2>/dev/null | sort || true)
FRAME_COUNT=$(printf '%s\n' "$FRAMES" | grep -c . || true)
echo "frames: $FRAME_COUNT"

if [ "$FRAME_COUNT" -gt 0 ]; then
    echo "sample frames:"
    printf '%s\n' "$FRAMES" | awk -v picks=6 '
        { f[NR] = $0; n = NR }
        END {
            if (picks > n) picks = n
            for (i = 0; i < picks; i++) {
                if (picks == 1) { idx = 1 }
                else { idx = int(i * (n - 1) / (picks - 1)) + 1 }
                print "  " f[idx]
            }
        }'
fi

echo "telemetry (last line):"
if [ -s "$OUT_DIR/telemetry.jsonl" ]; then
    tail -1 "$OUT_DIR/telemetry.jsonl"
else
    echo "  (missing)"
fi

echo "done.json:"
if [ -f "$OUT_DIR/done.json" ]; then
    cat "$OUT_DIR/done.json"
else
    echo "  (missing)"
fi
