#!/bin/sh
set -eu

repo_dir=$(CDPATH= cd -- "$(dirname "$0")/.." && pwd)
cd "$repo_dir"
dotnet_cli=${GUNS_DOTNET_CLI:-dotnet}

sh -n bin/deploy-web
node --check web/wwwroot/app.js
node --check web/wwwroot/hud.js
node --check web/wwwroot/multiplayer-config.js
node --check web/wwwroot/api/telemetry.js
node tools/assets/validate-manifests.mjs --strict
node tools/content/validate-governance.mjs --strict
asset_tests=$(find tools/assets -type f -name '*.test.mjs' -print | sort)
node --test $asset_tests
content_tests=$(find tools/content -type f -name '*.test.mjs' -print | sort)
node --test $content_tests
node --test tools/telemetry/test/*.test.mjs
runtime_tests=$(find web/wwwroot/render -type f -path '*/tests/*.test.mjs' -print | sort)
node --test $runtime_tests
node --test web/wwwroot/api/*.test.js
node --test world-worker/tests/*.test.mjs

scratch_dir=$(mktemp -d)
publish_dir="$scratch_dir/publish"
staged_content_dir="$scratch_dir/content"
dotnet_artifacts_dir="$scratch_dir/dotnet-artifacts"
trap 'rm -rf "$scratch_dir"' EXIT HUP INT TERM

node tools/assets/build-assets.mjs stage \
  --pack content/packs/korea-1950s/pack.json \
  --output "$staged_content_dir"
diff -qr "$staged_content_dir" web/wwwroot/content

"$dotnet_cli" restore GunsOnly.sln --nologo --ignore-failed-sources \
  --artifacts-path "$dotnet_artifacts_dir"
"$dotnet_cli" build GunsOnly.sln --configuration Release --no-restore --nologo \
  --artifacts-path "$dotnet_artifacts_dir"
"$dotnet_cli" test sim.Tests/GunsOnly.Sim.Tests.csproj \
  --configuration Release --no-build --nologo \
  --artifacts-path "$dotnet_artifacts_dir"
"$dotnet_cli" test server.Tests/GunsOnly.Server.Tests.csproj \
  --configuration Release --no-build --nologo \
  --artifacts-path "$dotnet_artifacts_dir"

"$dotnet_cli" publish web/GunsOnly.Web.csproj \
  --configuration Release --no-restore --nologo --output "$publish_dir" \
  --artifacts-path "$dotnet_artifacts_dir"

test -f "$publish_dir/wwwroot/index.html"
test -f "$publish_dir/wwwroot/_framework/blazor.webassembly.js"
test -f "$publish_dir/wwwroot/content/packs/korea-1950s/pack.json"
test -f "$publish_dir/wwwroot/render/assets/asset_registry.js"
test -f "$publish_dir/wwwroot/render/presence/global_room_client.js"
test -f "$publish_dir/wwwroot/multiplayer-config.js"
test -f "$publish_dir/wwwroot/api/telemetry.js"
test -f "$publish_dir/wwwroot/api/build-info.js"
test -f "$publish_dir/wwwroot/api/telemetry-admin.js"
test ! -f "$publish_dir/wwwroot/api/telemetry.test.js"
test ! -f "$publish_dir/wwwroot/api/telemetry-admin.test.js"
test ! -d "$publish_dir/wwwroot/render/presence/tests"
test ! -d "$publish_dir/wwwroot/render/telemetry/tests"
test ! -d "$publish_dir/wwwroot/lib/bootstrap"
test -f "$publish_dir/wwwroot/vercel.json"
rg -q '"source": "/telemetry-admin"' "$publish_dir/wwwroot/vercel.json"

# Browser smoke test: boot the published app in headless Chromium and require it reaches a running
# flight kernel (the #boot screen settles without the #fatal "FLIGHT KERNEL OFFLINE" modal). This is
# the only gate that executes app.js's real render path, so it catches boot regressions -- e.g. a
# deleted render helper that leaves syntax valid but breaks new FlightView() -- that every Node and
# .NET suite passes green. Set GUNS_SKIP_SMOKE=1 to skip it for a quick offline run.
if [ -z "${GUNS_SKIP_SMOKE:-}" ]; then
  (cd web/smoke && npm install --no-audit --no-fund --silent)
  if [ -n "${CI:-}" ]; then
    (cd web/smoke && npx --yes playwright install --with-deps chromium)
  else
    (cd web/smoke && npx --yes playwright install chromium)
  fi
  SMOKE_WWWROOT="$publish_dir/wwwroot" node --test web/smoke/smoke.test.mjs
else
  echo "Skipping browser smoke test (GUNS_SKIP_SMOKE set)."
fi

test -f world-worker/src/index.js
test -f world-worker/src/world.js
test -f world-worker/wrangler.jsonc

echo "Guns Only checks passed"
