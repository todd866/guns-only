#!/bin/sh
# Fast HEADLESS mission probe: runs a scenario through the real sim with NO rendering and
# prints the mission outcome. Frames cost ~4 min/run and tell you nothing about whether an
# intercept works -- that's physics. Use bin/rig when you need to SEE it; bin/mission to know
# if it happened. Same scenario files, same Rig autoload, same telemetry.
set -e
cd "$(dirname "$0")/.."
[ -z "$1" ] && { echo "usage: bin/mission <scenario>"; exit 2; }
SC="testrig/scenarios/$1.json"
[ -f "$SC" ] || { echo "no such scenario: $SC"; exit 2; }
OUT="testrig/out/$1"
rm -rf "$OUT"; mkdir -p "$OUT"
dotnet build GunsOnly.csproj -v q --nologo >/dev/null
GUNS_RIG_SCENARIO="$SC" GUNS_RIG_OUT="$OUT" bin/godot --headless --path . >/dev/null 2>&1 || true
python3 - "$OUT" "$1" <<'PY'
import json,sys,os
out,name=sys.argv[1],sys.argv[2]
p=os.path.join(out,'telemetry.jsonl')
if not os.path.exists(p): print("NO TELEMETRY — scenario did not run"); sys.exit(1)
rows=[json.loads(l) for l in open(p)]
h=lambda r:r['hud']
mn=min(rows,key=lambda r:h(r)['range_m'])
win=[r for r in rows if h(r)['gun_window']]
shots=h(rows[-1])['shots_total']; hits=h(rows[-1])['shots_in_window']
print(f"=== MISSION: {name} ===")
print(f"  duration        {rows[-1]['t']:.0f} s")
print(f"  start range     {h(rows[0])['range_m']:,.0f} m")
print(f"  MIN range       {h(mn)['range_m']:,.0f} m  at t={mn['t']:.0f}  (off {h(mn)['angle_off_deg']:.0f} deg, {h(mn)['speed_kts']:.0f} kt)")
if win: print(f"  GUN WINDOW      OPEN t={win[0]['t']:.1f}..{win[-1]['t']:.1f}  ({len(win)*0.1:.1f} s of firing opportunity)")
else:   print(f"  GUN WINDOW      never opened  -> NO SHOT. Mission failed.")
print(f"  trigger         {shots} pulls, {hits} inside the window")
print(f"  outcome         {'SHOT TAKEN' if hits else ('IN RANGE, NO TRIGGER' if win else 'NO INTERCEPT')}")
PY
