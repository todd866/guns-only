{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://guns-only.invalid/schemas/v1/content-pack.schema.json",
  "title": "Guns Only content pack",
  "description": "Declares versioned simulation content and presentation-profile IDs without coupling runtime selection to era or mission-name conditionals.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "packId",
    "packVersion",
    "displayName",
    "summary",
    "era",
    "theatre",
    "compatibility",
    "content",
    "presentation",
    "licensing"
  ],
  "properties": {
    "$schema": {
      "type": "string"
    },
    "schemaVersion": {
      "const": "1.0.0"
    },
    "packId": {
      "$ref": "#/$defs/id"
    },
    "packVersion": {
      "$ref": "#/$defs/semver"
    },
    "displayName": {
      "type": "string",
      "minLength": 1,
      "maxLength": 100
    },
    "summary": {
      "type": "string",
      "minLength": 1,
      "maxLength": 500
    },
    "status": {
      "type": "string",
      "enum": [
        "experimental",
        "preview",
        "stable",
        "deprecated"
      ],
      "default": "experimental"
    },
    "era": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "displayName",
        "startYear",
        "endYear"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/id"
        },
        "displayName": {
          "type": "string",
          "minLength": 1
        },
        "startYear": {
          "type": "integer",
          "minimum": 1900,
          "maximum": 2200
        },
        "endYear": {
          "type": "integer",
          "minimum": 1900,
          "maximum": 2200
        },
        "notes": {
          "type": "string"
        }
      }
    },
    "theatre": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "displayName"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/id"
        },
        "displayName": {
          "type": "string",
          "minLength": 1
        },
        "region": {
          "type": "string"
        },
        "referenceOrigin": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "latitude",
            "longitude"
          ],
          "properties": {
            "latitude": {
              "type": "number",
              "minimum": -90,
              "maximum": 90
            },
            "longitude": {
              "type": "number",
              "minimum": -180,
              "maximum": 180
            }
          }
        }
      }
    },
    "tags": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "$ref": "#/$defs/id"
      }
    },
    "compatibility": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "minimumPlatformVersion",
        "snapshotSchemaVersion",
        "supportedShells"
      ],
      "properties": {
        "minimumPlatformVersion": {
          "$ref": "#/$defs/semver"
        },
        "snapshotSchemaVersion": {
          "$ref": "#/$defs/semver"
        },
        "supportedShells": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "enum": [
              "web"
            ]
          }
        }
      }
    },
    "content": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "vehicleDefinitions",
        "missionDefinitions",
        "rulesets",
        "defaultMissionDefinitionId"
      ],
      "properties": {
        "vehicleDefinitions": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/registryRef"
          }
        },
        "missionDefinitions": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/registryRef"
          }
        },
        "rulesets": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "id",
              "mode",
              "displayName"
            ],
            "properties": {
              "id": {
                "$ref": "#/$defs/versionedId"
              },
              "mode": {
                "type": "string",
                "enum": [
                  "training_drill",
                  "discrete_sortie",
                  "continuous_operations"
                ]
              },
              "displayName": {
                "type": "string",
                "minLength": 1
              },
              "description": {
                "type": "string"
              }
            }
          }
        },
        "defaultMissionDefinitionId": {
          "$ref": "#/$defs/versionedId"
        }
      }
    },
    "presentation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "defaultPresentationProfileId",
        "profiles"
      ],
      "properties": {
        "defaultPresentationProfileId": {
          "$ref": "#/$defs/versionedId"
        },
        "profiles": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "id",
              "visualProfile",
              "assetProfileId",
              "cameraProfileId",
              "hudProfileId",
              "inputProfileId",
              "audioProfileId",
              "effectsProfileId"
            ],
            "properties": {
              "id": {
                "$ref": "#/$defs/versionedId"
              },
              "visualProfile": {
                "$ref": "#/$defs/packFileRef"
              },
              "assetProfileId": {
                "$ref": "#/$defs/versionedId"
              },
              "cameraProfileId": {
                "$ref": "#/$defs/versionedId"
              },
              "hudProfileId": {
                "$ref": "#/$defs/versionedId"
              },
              "inputProfileId": {
                "$ref": "#/$defs/versionedId"
              },
              "audioProfileId": {
                "$ref": "#/$defs/versionedId"
              },
              "effectsProfileId": {
                "$ref": "#/$defs/versionedId"
              }
            }
          }
        }
      }
    },
    "licensing": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "licenseSet",
        "requireExplicitAssetLicense"
      ],
      "properties": {
        "licenseSet": {
          "$ref": "#/$defs/packFileRef"
        },
        "requireExplicitAssetLicense": {
          "const": true
        }
      }
    },
    "extensions": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "$defs": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:[._-][a-z0-9]+)*$"
    },
    "versionedId": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:[._-][a-z0-9]+)*\\.v[1-9][0-9]*$"
    },
    "semver": {
      "type": "string",
      "pattern": "^(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)(?:-[0-9A-Za-z.-]+)?(?:\\+[0-9A-Za-z.-]+)?$"
    },
    "registryRef": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "uri"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/versionedId"
        },
        "uri": {
          "type": "string",
          "pattern": "^builtin://[a-zA-Z0-9._/-]+$"
        },
        "sha256": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        }
      }
    },
    "packFileRef": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "uri"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/versionedId"
        },
        "uri": {
          "$ref": "#/$defs/relativePath"
        },
        "sha256": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        }
      }
    },
    "relativePath": {
      "type": "string",
      "pattern": "^(?!/)(?!.*\\/$)(?![A-Za-z][A-Za-z0-9+.-]*:)(?!.*(?:^|/)\\.\\.(?:/|$))(?!.*\\\\)(?!.*//)[A-Za-z0-9][A-Za-z0-9._/-]*$"
    }
  }
}
