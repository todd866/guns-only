{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "headers": [
    {
      "source": "/content/packs/(.*)\\.glb",
      "has": [
        {
          "type": "query",
          "key": "sha256",
          "value": "^[0-9a-f]{64}$"
        }
      ],
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/content/packs/(.*)\\.terrain",
      "has": [
        {
          "type": "query",
          "key": "sha256",
          "value": "^[0-9a-f]{64}$"
        }
      ],
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/content/packs/(.*)\\.ktx2",
      "has": [
        {
          "type": "query",
          "key": "sha256",
          "value": "^[0-9a-f]{64}$"
        }
      ],
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/content/packs/(.*)\\.png",
      "has": [
        {
          "type": "query",
          "key": "sha256",
          "value": "^[0-9a-f]{64}$"
        }
      ],
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/content/packs/(.*)\\.webp",
      "has": [
        {
          "type": "query",
          "key": "sha256",
          "value": "^[0-9a-f]{64}$"
        }
      ],
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "X-Frame-Options", "value": "SAMEORIGIN" },
        { "key": "Content-Security-Policy", "value": "frame-ancestors 'self'" },
        { "key": "Strict-Transport-Security", "value": "max-age=63072000; includeSubDomains" }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/telemetry",
      "destination": "/api/telemetry"
    },
    {
      "source": "/telemetry-admin",
      "destination": "/api/telemetry-admin"
    }
  ]
}
